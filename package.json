{
  "name": "agent-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Web app to orchestrate Claude Code agents in Docker containers with inbox/outbox messaging",
  "author": "tobi936",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"tsx src/server/index.ts\" \"vite --config vite.config.ts\"",
    "build": "vite build --config vite.config.ts",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.json",
    "build:agent-image": "bash scripts/build-agent-image.sh"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "bcrypt": "^6.0.0",
    "chokidar": "^4.0.3",
    "dockerode": "^4.0.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lowdb": "^3.0.0",
    "nanoid": "^3.3.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/dockerode": "^3.3.42",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
