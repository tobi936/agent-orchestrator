# Copy to .env and fill in values

# Required for all services
JWT_SECRET=change-me-in-production-min-32-characters-here
INTERNAL_SECRET=internal-secret-change-me-32-characters
CREDENTIALS_SECRET=credentials-secret-change-me-32chars

# PostgreSQL — use a cloud DB in production (Supabase, Neon, Railway, etc.)
DATABASE_URL=postgres://orchestrator:orchestrator@localhost:5432/orchestrator

# Anthropic (needed for Claude provider)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Ollama base URL (when using local models)
# OLLAMA_BASE_URL=http://localhost:11434

# Service ports (defaults shown)
# PORT=3000               # api-gateway
# AGENT_MANAGER_PORT=3001
# MESSAGE_SERVICE_PORT=3002
