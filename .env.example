## Shared
# Lokal: normaler Connection String
# Neon DB (Vercel/Production): gepoolter URL (z.B. postgres://user:pass@ep-xxx.pooler.neon.tech/dbname?sslmode=require)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agent_orchestrator"
# Neon DB: direkter URL für Migrationen (prisma migrate / db push)
# Lokal: gleich wie DATABASE_URL
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/agent_orchestrator"

## apps/web
RUNNER_URL="http://localhost:3001"
# Password to access the web UI (leave empty to disable auth)
SITE_PASSWORD="changeme"

## apps/runner
PORT=3001

# AI Provider: ollama | anthropic | openai
PROVIDER=ollama

# Ollama Cloud
OLLAMA_API_KEY="your-ollama-api-key"
OLLAMA_MODEL="llama3.2"

# Anthropic (optional)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# OpenAI (optional)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# E2B (required for command-based agents)
E2B_API_KEY=""
# E2B — required for sandbox execution
E2B_API_KEY=""
