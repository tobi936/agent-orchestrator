generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agent {
  id                String      @id @default(uuid())
  name              String
  systemPrompt      String
  provider          String      @default("ollama")
  model             String      @default("gpt-oss:20b")
  command           String?
  repoUrl           String?
  status            AgentStatus @default(STOPPED)
  containerId       String?
  maxToolIterations Int         @default(100)
  allowedTools      String[]
  createdAt         DateTime    @default(now())

  tasks     Task[] @relation("AgentTasks")
  sentTasks Task[] @relation("SentTasks")
}

enum AgentStatus {
  STOPPED
  RUNNING
}

model Task {
  id          String     @id @default(uuid())
  agentId     String
  agent       Agent      @relation("AgentTasks", fields: [agentId], references: [id], onDelete: Cascade)
  fromAgentId String?
  fromAgent   Agent?     @relation("SentTasks", fields: [fromAgentId], references: [id], onDelete: SetNull)
  title       String
  content     String
  status      TaskStatus @default(PENDING)
  forHuman    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  thread      TaskMessage[]
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model TaskMessage {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  role      String   // "user" | "agent"
  content   String
  createdAt DateTime @default(now())
}
