# Copy to secrets.yaml and fill in values. Never commit secrets.yaml!
# Apply: kubectl apply -f k8s/secrets.yaml
apiVersion: v1
kind: Secret
metadata:
  name: orchestrator-secrets
  namespace: agent-orchestrator
type: Opaque
stringData:
  DATABASE_URL: "postgres://user:password@your-cloud-db-host:5432/orchestrator"
  JWT_SECRET: "your-jwt-secret-min-32-characters-here"
  INTERNAL_SECRET: "your-internal-secret-min-32-characters"
  ANTHROPIC_API_KEY: "sk-ant-..."
  CREDENTIALS_SECRET: "your-credentials-secret-min-32-chars"
